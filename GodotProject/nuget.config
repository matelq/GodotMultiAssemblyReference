<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="LocalGodotConv" value="C:\Users\user\MyLocalNugetSource-conv" />
  </packageSources>
  <packageSourceMapping>
    <!-- Only the three local test-fixture modules are pinned to the local feed.
         CrackTower.Godot.* and everything else resolve from nuget.org. -->
    <packageSource key="LocalGodotConv">
      <package pattern="ExternalNuGetModule" />
      <package pattern="TransitiveNuGetFromNuGet" />
      <package pattern="TransitiveNuGetFromProject" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
